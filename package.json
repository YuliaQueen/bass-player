{
    "name": "bass-tabs-player",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "concurrently -n front,back -c cyan,magenta \"npm:dev:front\" \"npm:dev:back\"",
        "dev:front": "vite",
        "dev:back": "node --watch server/index.js",
        "build": "vite build",
        "preview": "concurrently -n front,back -c cyan,magenta \"vite preview\" \"node server/index.js\"",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@coderline/alphatab": "^1.6.0",
        "cors": "^2.8.5",
        "express": "^4.21.2",
        "multer": "^2.0.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.18.0",
        "@vitest/coverage-v8": "^2.1.8",
        "concurrently": "^9.1.2",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^9.1.0",
        "globals": "^15.14.0",
        "prettier": "^3.4.2",
        "supertest": "^7.0.0",
        "vite": "^6.0.7",
        "vite-plugin-static-copy": "^2.2.0",
        "vitest": "^2.1.8"
    }
}
